# --- Contact intake ---
# Direct GHL API integration. Production requires these so website leads land in
# the Jennifer R. Berman, MD GHL location.
GHL_BERMAN_API_TOKEN=
GHL_BERMAN_LOCATION_ID=
LEAD_DELIVERY_REQUIRE_GHL=true
# Optional overrides. Defaults should target Marketing Pipeline / New Leads.
GHL_BERMAN_PIPELINE_ID=
GHL_BERMAN_PIPELINE_STAGE_ID=
LEAD_DELIVERY_CREATE_GHL_OPPORTUNITY=true

# Optional generic intake webhook fallback/sidecar.
GHL_LEAD_WEBHOOK_URL=
CONTACT_INTAKE_WEBHOOK_URL=
LEAD_DELIVERY_REQUIRE_WEBHOOK=false
LEAD_DELIVERY_REQUIRE_EMAIL=false

# Optional direct staff notification email. Prefer a GHL workflow trigger for
# front-desk/Dr. Berman emails so contact creation and notifications stay in GHL.
RESEND_API_KEY=
LEAD_NOTIFICATION_FROM=
LEAD_NOTIFICATION_TO=
LEAD_NOTIFICATION_CC=

# --- Analytics / Verification ---
NEXT_PUBLIC_SITE_URL=https://bermansexualhealth.com
# Public GA4 measurement ID. Leave blank to disable Google Analytics loading.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Public Google Search Console HTML tag content value.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
